# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# project folder — exclude all files except the shipped config TOMLs
# src/bank_statement_parser/project/**/*.*
# !src/bank_statement_parser/project/config/*.toml

#performance profiling tools
*profile.*

#any database, pdf, parquet or log files
*.db*
*.parquet
*.log
# Block ALL PDFs by default (security: no accidental sensitive data commits)
*.pdf
# Exception: Allow ONLY synthetic PDFs (deterministic, no real data)
!tests/fixtures/pdfs/synthetic/**/*.pdf
!src/bank_statement_parser/test_data/pdfs/**/synthetic_*.pdf
*.csv
*.xlsx
*.json
*.xls

# anonymise.toml contains real PII — never commit it
anonymise.toml

# test project directories (created and deleted by integration tests)
tests/test_project/
tests/test_project_bad/

# apple files
.DS_Store

# MkDocs build output
site/