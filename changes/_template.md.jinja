{%- for section, _ in sections.items() %}
{%- if section %}
{{ "\n" }}### {{ section }}
{%- endif %}

{#- First pass: render non-internal categories #}
{%- for category, definition in definitions.items() if category in sections[section] %}
{%- if category != "internal" %}
{{ "\n" }}#### {{ definition.name }}
{%- for text, _ in sections[section][category].items() %}
{%- if text %}
{{ "\n" }}- {{ text }}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- endfor %}

{#- Second pass: render internal categories in a collapsed details block #}
{%- set ns = namespace(has_internal=false) %}
{%- for category, definition in definitions.items() if category in sections[section] %}
{%- if category == "internal" %}
{%- for text, _ in sections[section][category].items() %}
{%- if text %}
{%- set ns.has_internal = true %}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- if ns.has_internal %}
{{ "\n" }}<details>
{{ "\n" }}<summary>Internal Changes</summary>
{%- for category, definition in definitions.items() if category in sections[section] %}
{%- if category == "internal" %}
{%- for text, _ in sections[section][category].items() %}
{%- if text %}
{{ "\n" }}- {{ text }}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- endfor %}
{{ "\n" }}</details>
{%- endif %}
{%- endfor %}
